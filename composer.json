{
    "name": "myvendor/my-silverstripe-project",
    "description": "A Silverstripe project",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "silverstripe/recipe-core": "5.1.0@stable",
        "silverstripe/recipe-cms": "5.1.0@stable",
        "silverstripe/login-forms": "5.1.0@stable",
        "silverstripe-themes/simple": "*",
        "phpoffice/phpword": "^1.0",
        "smalot/pdfparser": "^2.0",
        "silverstripe/sqlite3": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "classmap": [
            "app/src/"
        ]
    },
    "config": {
        "process-timeout": 600,
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "silverstripe/recipe-plugin": true
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "extra": {
        "project-files-installed": [
            ".htaccess",
            "app/.htaccess",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ]
    }
}
